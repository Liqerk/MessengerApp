<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- Тулбар -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/bg_toolbar"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Назад"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Профиль"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Блок Аватара -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <FrameLayout
                    android:id="@+id/avatar_container"
                    android:layout_width="96dp"
                    android:layout_height="96dp">

                    <ImageView
                        android:id="@+id/profile_avatar_image"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Аватарка"/>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:src="@drawable/ic_camera"
                        android:background="@drawable/camera_badge_background"
                        android:padding="4dp"
                        android:contentDescription="Сменить"/>

                    <TextView
                        android:id="@+id/profile_avatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/avatar_background"
                        android:gravity="center"
                        android:textColor="@color/text_on_primary"
                        android:textSize="40sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/profile_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:id="@+id/profile_mail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Настройки"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <!-- Избранное -->
            <LinearLayout
                android:id="@+id/favorites_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⭐ Избранное"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- Смена логина -->
            <LinearLayout
                android:id="@+id/change_name_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Изменить логин"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- Смена пароля -->
            <LinearLayout
                android:id="@+id/change_password_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Изменить пароль"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- DPI Обход блокировок -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🛡️ Обход блокировок (DPI)"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/dpi_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- НОВЫЙ БЛОК: РЕЖИМ РАБОТЫ (Сервер/Локально) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌐 Серверный режим"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"/>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/mode_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/server_url_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="http://10.0.2.2:8080"
                    android:textSize="14sp"
                    android:padding="12dp"

                    android:textColor="@color/bg_input"
                    android:background="@android:drawable/editbox_background"
                    android:inputType="textUri"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Messenger v1.0"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>